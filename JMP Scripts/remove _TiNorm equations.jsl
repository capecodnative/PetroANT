Names Default To Here( 1 );

dt = Current Data Table();
allColNames = dt << Get Column Names( "String" );

For( i = 1, i <= N Items( allColNames ), i++,
	thisName = allColNames[i];

	If( Ends With( Lowercase( thisName ), "_normti" ),
		col = Column( dt, thisName );
		vals = col << Get Values;
		col << Delete Formula;
		col << Set Each Value( vals[Row()] );
	);
);